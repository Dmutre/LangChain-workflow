# LLM backend: gemini | google | anthropic | claude | openai | chatgpt
LLM_PROVIDER=gemini

# API key for the provider you use (only that one is required at runtime)
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (defaults are sensible per provider)
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-haiku-4-5
# OPENAI_MODEL=gpt-4o-mini

# Optional
# LOG_LEVEL=debug
# SAVE_TRACE=1
# TRACE_DIR=./logs

# Demo / credits: `pnpm demo` or `node dist/cli.js --demo` uses short samples/demo-alert.json (one minimal run)
# DEMO=1
# DEMO_MODE=1

{
  "name": "LangChainTest",
  "version": "1.0.0",
  "description": "AI-powered production alert triage — LangChain + LangGraph (classify, similar incidents, runbooks, notifications).",
  "type": "module",
  "main": "./dist/agent/triage-graph.js",
  "types": "./dist/agent/triage-graph.d.ts",
  "scripts": {
    "build": "tsc",
    "demo": "node dist/cli.js --demo",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.all.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.6.2",
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "dotenv": "^17.4.0",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.2"
  }
}
